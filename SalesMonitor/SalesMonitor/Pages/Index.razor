@page "/"
@using Microsoft.EntityFrameworkCore
@using SalesMonitor.Data
@using SalesMonitor.Models
@using Microsoft.AspNetCore.SignalR.Client
@inject AppDbContext Db
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Мониторинг продаж</PageTitle>

<div style="max-width: 1200px; margin: 0 auto; padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="margin: 0;">
            Мониторинг активности клиентов
        </h2>
        <span style="background: #0d6efd; color: white; padding: 5px 12px; border-radius: 5px; font-size: 14px;">
            Онлайн
        </span>
    </div>

    @if (_alerts.Any())
    {
        <div style="margin-bottom: 20px;">
            @foreach (var alert in _alerts)
            {
                <div style="background: #fff3cd; border: 1px solid #ffc107; padding: 12px; margin-bottom: 8px; border-radius: 8px;">
                     <strong>@alert.ProductName</strong>: @alert.Message
                    <small style="color: gray; margin-left: 10px;">@alert.Timestamp.ToString("HH:mm:ss")</small>
                </div>
            }
        </div>
    }

    <div style="background: white; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); overflow: hidden;">
        <div style="padding: 16px 20px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between;">
            <h5 style="margin: 0;"> Продукты</h5>
            <span style="color: gray;">Всего: @_activities.Count</span>
        </div>
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8f9fa;">
                    <th style="padding: 12px 20px; text-align: left;">Продукт</th>
                    <th style="padding: 12px 20px; text-align: left;">Последняя продажа</th>
                    <th style="padding: 12px 20px; text-align: left;">Средний интервал</th>
                    <th style="padding: 12px 20px; text-align: left;">Дней без продаж</th>
                    <th style="padding: 12px 20px; text-align: left;">Статус</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _activities)
                {
                    var days = (DateTime.Today - item.LastSaleDate?.Date)?.Days ?? 0;
                    var isRisk = days > (double)(item.AverageOrderInterval * 2.5m) && item.AverageOrderInterval > 0;
                    <tr style="@(isRisk ? "background: #ffe0e0;" : "") border-bottom: 1px solid #eee;">
                        <td style="padding: 12px 20px;">@item.Product.Name</td>
                        <td style="padding: 12px 20px;">@(item.LastSaleDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                        <td style="padding: 12px 20px;">@item.AverageOrderInterval.ToString("F1") дн</td>
                        <td style="padding: 12px 20px; @(isRisk ? "color: red; font-weight: bold;" : "")">@days дн</td>
                        <td style="padding: 12px 20px;">
                            @if (isRisk)
                            {
                                <span style="background: #dc3545; color: white; padding: 4px 10px; border-radius: 4px; font-size: 13px;">
                                    Риск ухода!
                                </span>
                            }
                            else
                            {
                                <span style="background: #198754; color: white; padding: 4px 10px; border-radius: 4px; font-size: 13px;">
                                     Норма
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<ClientActivity> _activities = new();
    private List<AlertNotification> _alerts = new();
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        _activities = await Db.ClientActivities
            .Include(a => a.Product)
            .ToListAsync();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/alertHub"))
            .Build();

        _hubConnection.On<AlertNotification>("ReceiveAlert", alert =>
        {
            _alerts.Insert(0, alert);
            if (_alerts.Count > 5) _alerts.RemoveAt(_alerts.Count - 1);
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
            await _hubConnection.DisposeAsync();
    }
}